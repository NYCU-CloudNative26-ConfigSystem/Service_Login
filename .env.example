# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/auth_service

# Redis
REDIS_URL=redis://localhost:6379/0

# Email verification / password reset code
EMAIL_VERIFICATION_CODE_TTL_SECONDS=600
PASSWORD_RESET_CODE_TTL_SECONDS=600

# Email provider: mock | mailtrap | brevo | ses
EMAIL_PROVIDER=mock
EMAIL_FROM=no-reply@example.com

# Mailtrap (SMTP)
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USERNAME=
MAILTRAP_PASSWORD=
MAILTRAP_USE_TLS=True

# Brevo
BREVO_API_KEY=

# Amazon SES
SES_REGION=us-east-1
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=Login Service
DEBUG=True
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000

# Docker host mapping (host:container = APP_HOST_PORT:APP_PORT)
# Use a non-8000 host port by default to avoid conflicts with local services/ngrok
APP_HOST_PORT=18000
